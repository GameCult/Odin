+/**
+ * Enable reference blob tracking without writing controller LEDs.
+ * The caller owns LED output and supplies the expected fully-saturated RGB hue.
+ */
+ADDAPI enum PSMoveTracker_Status
+ADDCALL psmove_tracker_enable_color_observer(PSMoveTracker *tracker, PSMove *move,
+        unsigned char r, unsigned char g, unsigned char b);
+
+/**
+ * Change the expected RGB hue for an observer-enabled controller without
+ * writing controller LEDs or running blinking calibration.
+ */
+ADDAPI bool
+ADDCALL psmove_tracker_set_expected_color(PSMoveTracker *tracker, PSMove *move,
+        unsigned char r, unsigned char g, unsigned char b);
