{
  "name": "@gamecult/odin",
  "version": "0.1.0",
  "private": true,
  "description": "GameCult all-seer: CultMesh Verse discovery, schema awareness, translation, and Eve surface publication.",
  "type": "commonjs",
  "scripts": {
    "gjallar:persona": "node scripts/write-gjallar-persona-cc.mjs inspect",
    "gjallar:persona:write": "node scripts/write-gjallar-persona-cc.mjs write",
    "gjallar:build": "cargo build -p gjallar-daemon",
    "gjallar:start": "cargo run -p gjallar-daemon --",
    "idunn:build": "cargo build -p idunn-daemon",
    "idunn:start": "cargo run -p idunn-daemon --",
    "sleipnir:build": "cargo build -p sleipnir-daemon",
    "sleipnir:start": "cargo run -p sleipnir-daemon --",
    "muninn:build": "cargo build -p muninn-daemon",
    "muninn:start": "cargo run -p muninn-daemon --",
    "hermodr:start": "node src/hermodr-daemon.cjs",
    "rust:test": "cargo test --workspace",
    "check": "node scripts/check-syntax.cjs",
    "test": "node --test test/*.test.cjs",
    "start": "node src/odin-coordinator.cjs"
  },
  "engines": {
    "node": ">=20"
  }
}
