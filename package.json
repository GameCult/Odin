{
  "name": "@gamecult/odin",
  "version": "0.1.0",
  "private": true,
  "description": "GameCult all-seer: CultMesh Verse discovery, schema awareness, translation, and Eve surface publication.",
  "type": "commonjs",
  "scripts": {
    "gjallar:persona": "node scripts/write-gjallar-persona-cc.mjs inspect",
